<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <runtime>
    <!-- Let [HandleProcessCorruptedStateExceptions] on Main actually catch an
         access violation raised inside the native side of Vapi.Net.dll, so a
         hard crash becomes a logged line + clean exit instead of the process
         silently vanishing. Diagnostic aid only - we don't pretend to recover
         a corrupted process, we just want it to say what killed it. -->
    <legacyCorruptedStateExceptionsPolicy enabled="true" />
    <!-- The vendor DLL is .NET Framework 4.x mixed-mode; nothing here needs
         concurrent GC, and a single-threaded collector is one less variable
         when chasing a delegate-lifetime crash. -->
    <gcConcurrent enabled="false" />
  </runtime>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5.1" />
  </startup>
</configuration>
